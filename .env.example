# ── LLM ─────────────────────────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo

# ── App mode ─────────────────────────────────────────────────────────────────
# Set DEMO_MODE=false once you have an OpenAI key.
# In demo mode agents return rule-based answers without any LLM call.
DEMO_MODE=true

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=inventory-intelligence

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
